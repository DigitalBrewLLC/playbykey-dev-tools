{
  "name": "@playbykey/theory",
  "version": "1.0.0",
  "description": "Zero-dependency TypeScript music theory engine for scales, modes, intervals, and key relationships.",
  "keywords": [
    "music-theory",
    "typescript",
    "scales",
    "modes",
    "intervals",
    "key-signatures",
    "diatonic",
    "pentatonic",
    "blues-scale",
    "harmonic-minor",
    "zero-dependencies",
    "mcp"
  ],
  "homepage": "https://theory-engine.docs.playbykey.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/DigitalBrewLLC/playbykey-dev-tools"
  },
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
